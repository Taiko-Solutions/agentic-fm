<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.agenticfm.webviewer-docker</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>"__ROOT__/ops/services/start_webviewer_docker.sh"</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__ROOT__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>300</integer>
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/agentic-fm/webviewer-docker.launchd.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/agentic-fm/webviewer-docker.launchd.log</string>
</dict>
</plist>

